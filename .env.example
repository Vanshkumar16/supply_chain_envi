# .env.example — Supply Chain Disruption Management OpenEnv
# Copy to .env and fill in your values before running inference.py

# ── LLM Inference (required for inference.py) ─────────────────────────────
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct
HF_TOKEN=hf_your_huggingface_token_here

# ── Environment server (optional override) ────────────────────────────────
# Default is http://localhost:8000 when running locally
# For HF Space: https://your-username-supply-chain-env.hf.space
ENV_BASE_URL=http://localhost:8000
