# OpenEnv Model Configuration
# Copy to .env and fill in your values

# Use local model instead of API (requires setup_model.py first)
USE_LOCAL_MODEL=true

# Hugging Face model ID for OpenEnv
LOCAL_MODEL_ID=openenv/supply-chain-model

# Hugging Face API token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# For API-based models (when USE_LOCAL_MODEL=false):
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct

# Supply chain environment settings
ENV_BASE_URL=http://localhost:8000
